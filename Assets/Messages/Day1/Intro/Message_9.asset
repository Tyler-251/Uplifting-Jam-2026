  m_Script: {fileID: 11500000, guid: 69498aa934a04754eae86e5d7cd821a5, type: 3}
  m_Name: Message_9
  m_EditorClassIdentifier: Assembly-CSharp::MessageSO
  speakerName: Old Man
  messageText: No, No, No. None of that nonsense. You are going to sit here with
    me and play a game. Have you ever played Tic-Tac-Toe?
  profilePicture: {fileID: -1920826564622356544, guid: 42e0ccb7c033c0347be0db5d51dea375, type: 3}
  graphicPicture: {fileID: 0}
  gurbleClip: {fileID: 8300000, guid: 72d1da1fdd67e7a42a884f04271daae5, type: 3}
  choices:
  - choiceText: Do you think I've been living under a rock? Of course I've played
      Tic-Tac-Toe.
    onChoose:
      m_PersistentCalls:
        m_Calls: []
    nextMessage: {fileID: 11400000, guid: 416270693f4e75a42888b11dc9572afc, type: 2}
  - choiceText: '[Lie] No'
